#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    char *s;
    s = malloc(1001 * sizeof(char));
    if (scanf("%[^\n]", s) != 1) {
        free(s);
        return 0;
    }
    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] == ' ') {
            printf("\n");
        } else {
            printf("%c", s[i]);
        }
    }
    printf("\n");
    free(s);
    
    return 0;
}
